{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "frontend-build-check",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd frontend && npm run build"
			],
			"isBackground": false
		},
		{
			"label": "run-backend-dev",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd backend && npm run dev"
			],
			"isBackground": true
		},
		{
			"label": "run-frontend-dev",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"cd frontend && npm start"
			],
			"isBackground": true
		}
	]
}